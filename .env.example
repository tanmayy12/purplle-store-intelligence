STORE_ID=ST1008
STORE_NAME=Brigade_Bangalore
OPERATING_DATE=2026-04-10
TZ=Asia/Kolkata

DATABASE_URL=postgresql://store:YOUR_PASSWORD@postgres:5432/store_intelligence

KAFKA_BOOTSTRAP=redpanda:9092
KAFKA_GROUP_ID=analytics-api
KAFKA_TOPIC_RAW=store.tracking.raw
KAFKA_TOPIC_ANOMALIES=store.anomalies
KAFKA_TOPIC_SESSION=store.tracking.session
KAFKA_TOPIC_DLQ=store.tracking.dlq

KAFKA_RETRY_MAX_ATTEMPTS=5
KAFKA_RETRY_INITIAL_DELAY_SEC=1
KAFKA_RETRY_MAX_DELAY_SEC=30

ZONES_CONFIG_PATH=/config/zones/zones.yaml
POS_CSV_PATH=/data/seed/ground_truth_pos.csv

SESSION_TIMEOUT_SEC=1800
REENTRY_COOLDOWN_SEC=120
BOUNCE_THRESHOLD_SEC=30
ENGAGED_MIN_SEC=60
CHECKOUT_MIN_SEC=15

POS_MATCH_WINDOW_BEFORE_SEC=600
POS_MATCH_WINDOW_AFTER_SEC=120

VIDEO_PATH=
VIDEO_DIR=/data/cctv

YOLO_MODEL=yolov8n.pt
FRAME_SKIP=2
SIMULATION_MODE=always

DETECTION_CONFIDENCE_THRESHOLD=0.3
STAFF_ZONE_DWELL_THRESHOLD_FRAMES=30
TRACK_LOSS_TIMEOUT_SEC=5

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000